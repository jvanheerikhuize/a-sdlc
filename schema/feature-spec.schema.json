{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asdlc/schema/feature-spec.schema.json",
  "title": "A-SDLC Feature Specification",
  "description": "Schema for feature/change specifications produced during Stage 1 (Intent Ingestion). Referenced by control QC-1A.",
  "type": "object",
  "required": ["metadata", "description", "acceptance_criteria"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["id", "title", "version", "status", "priority", "author", "created_at", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^FEAT-[0-9]{4}$",
          "description": "Unique identifier. Format: FEAT-NNNN (e.g. FEAT-0001)."
        },
        "title": { "type": "string", "minLength": 3 },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "approved", "implemented", "deprecated"]
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "description": {
      "type": "object",
      "required": ["summary", "problem_statement", "proposed_solution"],
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string" },
        "problem_statement": { "type": "string" },
        "proposed_solution": { "type": "string" },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^AC-[0-9]{3}$" },
          "given": { "type": "string" },
          "when": { "type": "string" },
          "then": { "type": "string" },
          "and": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "technical_requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "constraints": { "type": "array", "items": { "type": "string" } },
        "performance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "response_time_ms": { "type": "integer" },
            "throughput": { "type": "string" },
            "availability": { "type": "string" }
          }
        },
        "security": { "type": "array", "items": { "type": "string" } },
        "scalability": { "type": "string" }
      }
    },
    "api_changes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "new_endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["method", "path", "description"],
            "additionalProperties": false,
            "properties": {
              "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "modified_endpoints": { "type": "array", "items": { "type": "string" } },
        "breaking_changes": { "type": "boolean" }
      }
    },
    "ui_changes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wireframes": { "type": "array", "items": { "type": "string" } },
        "components": { "type": "array", "items": { "type": "string" } }
      }
    },
    "testing_requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit_tests": { "type": "boolean" },
        "integration_tests": { "type": "boolean" },
        "e2e_tests": { "type": "boolean" },
        "performance_tests": { "type": "boolean" },
        "test_scenarios": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rollout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "feature_flag": { "type": "string" },
        "rollout_strategy": {
          "type": "string",
          "enum": ["immediate", "gradual", "canary", "beta"]
        },
        "rollback_plan": { "type": "string" }
      }
    },
    "risk_classification": {
      "type": "object",
      "additionalProperties": false,
      "description": "Populated by RC-1A (risk classification) and AC-1A (EU AI Act tier).",
      "properties": {
        "risk_tier": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "Non-functional risk exposure tier from RC-1A."
        },
        "ai_act_tier": {
          "type": "string",
          "enum": ["minimal", "limited", "high", "unacceptable", "not_applicable"],
          "description": "EU AI Act risk tier from AC-1A. Only populated for AI components."
        },
        "governance_intensity": {
          "type": "string",
          "enum": ["standard", "enhanced", "full"],
          "description": "Governance intensity level determined by RC-1A."
        }
      }
    }
  }
}
