{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asdlc/schema/framework.schema.json",
  "title": "A-SDLC Framework Schema",
  "description": "Validates asdlc.yaml — the root framework manifest defining stages, controls, and governance",
  "type": "object",
  "required": ["framework", "roles", "cross_cutting", "stages", "supporting_files"],
  "properties": {
    "framework": {
      "type": "object",
      "required": ["name", "abbreviation", "version", "status", "tagline", "narrative", "regulatory_scope", "control_tracks", "delegation_patterns"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Framework name"
        },
        "abbreviation": {
          "type": "string",
          "description": "Framework abbreviation (e.g., A-SDLC)"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "description": "Framework version (e.g., 1.0)"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "approved"],
          "description": "Framework status"
        },
        "tagline": {
          "type": "string",
          "minLength": 1,
          "description": "One-line framework description"
        },
        "narrative": {
          "type": "object",
          "required": ["what_is_it", "properties", "value_propositions"],
          "properties": {
            "what_is_it": {
              "type": "string",
              "minLength": 1,
              "description": "Narrative explanation of the framework"
            },
            "properties": {
              "type": "array",
              "minItems": 1,
              "description": "Key properties of the framework",
              "items": {
                "type": "string"
              }
            },
            "value_propositions": {
              "type": "array",
              "minItems": 1,
              "description": "Value propositions for adopting the framework",
              "items": {
                "type": "object",
                "required": ["benefit", "target"],
                "properties": {
                  "benefit": {
                    "type": "string",
                    "minLength": 1
                  },
                  "target": {
                    "type": "string",
                    "minLength": 1
                  },
                  "mechanism": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "regulatory_scope": {
          "type": "array",
          "minItems": 1,
          "description": "Regulatory frameworks this A-SDLC addresses",
          "items": {
            "type": "string",
            "enum": ["DORA", "EU AI Act", "ISO 27001"]
          }
        },
        "regulatory_summary": {
          "type": "object",
          "description": "Summary of regulatory coverage",
          "properties": {
            "frameworks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "full_name", "controls_mapped", "total_controls", "coverage_pct"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "full_name": {
                    "type": "string"
                  },
                  "regulation": {
                    "type": "string"
                  },
                  "controls_mapped": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "total_controls": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "coverage_pct": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 100
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "control_tracks": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "description": "Five control tracks",
          "items": {
            "type": "object",
            "required": ["code", "name", "description"],
            "properties": {
              "code": {
                "$ref": "https://asdlc/schema/common.schema.json#/$defs/track_code"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string",
                "minLength": 1
              },
              "control_count": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "delegation_patterns": {
          "type": "array",
          "minItems": 1,
          "description": "Supported delegation patterns",
          "items": {
            "type": "object",
            "required": ["pattern", "description"],
            "properties": {
              "pattern": {
                "$ref": "https://asdlc/schema/common.schema.json#/$defs/delegation_pattern"
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "roles": {
      "type": "object",
      "description": "Actor roles in the framework",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "cross_cutting": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string"
        },
        "feedback_loops": {
          "type": "object",
          "properties": {
            "definition": {
              "type": "string"
            },
            "process": {
              "type": "string"
            },
            "readme": {
              "type": "string"
            },
            "artifacts_dir": {
              "type": "string"
            },
            "autofix_templates_dir": {
              "type": "string"
            }
          }
        },
        "directives": {
          "type": "object",
          "properties": {
            "core": {
              "type": "string"
            },
            "stages": {
              "type": "string"
            }
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "track"],
            "properties": {
              "id": {
                "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
              },
              "name": {
                "type": "string"
              },
              "track": {
                "$ref": "https://asdlc/schema/common.schema.json#/$defs/track_code"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "stages": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "description": "The six stages of the A-SDLC",
      "items": {
        "type": "object",
        "required": ["number", "name", "slug", "directory", "stage_file", "readme", "description", "controls"],
        "properties": {
          "number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "name": {
            "$ref": "https://asdlc/schema/common.schema.json#/$defs/stage_name"
          },
          "slug": {
            "type": "string",
            "pattern": "^[0-9]{2}-[a-z-]+$"
          },
          "directory": {
            "type": "string",
            "pattern": "^stages/[0-9]{2}-[a-z-]+$"
          },
          "stage_file": {
            "type": "string"
          },
          "readme": {
            "type": "string"
          },
          "artifacts_dir": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "controls": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "name", "track"],
              "properties": {
                "id": {
                  "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
                },
                "name": {
                  "type": "string"
                },
                "track": {
                  "$ref": "https://asdlc/schema/common.schema.json#/$defs/track_code"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "supporting_files": {
      "type": "object",
      "description": "References to supporting configuration files",
      "properties": {
        "schema": {
          "type": "object"
        },
        "registry": {
          "type": "string"
        },
        "regulatory": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
