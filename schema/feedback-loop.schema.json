{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asdlc/schema/feedback-loop.schema.json",
  "title": "Feedback Loop Workflow Schema",
  "description": "Validates feedbackloops/feedback-loops.yaml — feedback path definitions and workflow steps",
  "type": "object",
  "required": ["process", "roles", "input_artifacts", "steps", "feedback_loops"],
  "properties": {
    "process": {
      "type": "string",
      "description": "Reference to feedback loop process documentation"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "description": "Actor roles involved in feedback loops",
      "items": {
        "type": "object",
        "required": ["role_code", "role_name", "responsibilities"],
        "properties": {
          "role_code": {
            "type": "string",
            "pattern": "^[A-Z]{2,3}$",
            "description": "Role abbreviation"
          },
          "role_name": {
            "type": "string",
            "minLength": 1
          },
          "responsibilities": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "input_artifacts": {
      "type": "object",
      "description": "Input artifacts required by feedback loops, keyed by stage name",
      "properties": {
        "stage4": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact", "source_control", "source_step"],
            "properties": {
              "artifact": {
                "type": "string"
              },
              "source_control": {
                "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
              },
              "source_step": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "stage6": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact", "source_control", "source_step"],
            "properties": {
              "artifact": {
                "type": "string"
              },
              "source_control": {
                "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
              },
              "source_step": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "description": "Feedback loop execution steps",
      "items": {
        "type": "object",
        "required": ["id", "name", "runs"],
        "properties": {
          "id": {
            "$ref": "https://asdlc/schema/common.schema.json#/$defs/feedback_step_id"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "delegation": {
            "type": "string"
          },
          "delegation_description": {
            "type": "string"
          },
          "runs": {
            "type": "string"
          },
          "path_ref": {
            "$ref": "https://asdlc/schema/common.schema.json#/$defs/feedback_path_id"
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["actor", "action"],
              "properties": {
                "actor": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "on_ambiguity": {
            "type": "string"
          },
          "on_deviation": {
            "type": "string"
          },
          "retention": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "output_artifacts": {
      "type": "array",
      "description": "Artifacts produced by feedback loops",
      "items": {
        "type": "object",
        "required": ["artifact", "produced_at", "template"],
        "properties": {
          "artifact": {
            "type": "string"
          },
          "produced_at": {
            "type": "string"
          },
          "template": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Artifact file references",
      "properties": {
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "autofix_templates_dir": {
      "type": "string",
      "description": "Directory containing autofix templates"
    },
    "feedback_loops": {
      "type": "array",
      "minItems": 2,
      "description": "Feedback loop path definitions",
      "items": {
        "type": "object",
        "required": ["id", "name", "re_entry_stage", "re_entry_stage_name", "description"],
        "properties": {
          "id": {
            "$ref": "https://asdlc/schema/common.schema.json#/$defs/feedback_path_id"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "re_entry_stage": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "re_entry_stage_name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "trigger_sources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["stage", "name", "source_controls"],
              "properties": {
                "stage": {
                  "type": "integer",
                  "minimum": 4,
                  "maximum": 6
                },
                "name": {
                  "type": "string"
                },
                "source_controls": {
                  "type": "array",
                  "items": {
                    "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
                  }
                },
                "description": {
                  "type": "string"
                },
                "eligibility": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "minimum_controls": {
            "oneOf": [
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "name"],
                  "properties": {
                    "id": {
                      "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
                    },
                    "name": {
                      "type": "string"
                    },
                    "rationale": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              {
                "type": "object",
                "required": ["scope", "stages"],
                "properties": {
                  "scope": {
                    "type": "string",
                    "enum": ["full_lifecycle"]
                  },
                  "stages": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["number", "controls"],
                      "properties": {
                        "number": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 6
                        },
                        "controls": {
                          "type": "array",
                          "items": {
                            "$ref": "https://asdlc/schema/common.schema.json#/$defs/control_id"
                          }
                        },
                        "note": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "regulatory_mapping": {
            "type": "object",
            "properties": {
              "dora": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "article": {
                      "type": "string"
                    },
                    "obligation": {
                      "type": "string"
                    }
                  }
                }
              },
              "eu_ai_act": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "article": {
                      "type": "string"
                    },
                    "obligation": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
